@model WeddingPlanner.Core.Models.Partner
@{
    ViewData["Title"] = "ObriÜi partnera";
}

<div class="alert alert-danger">
    <h4>Potvrda brisanja</h4>
    <p>Sigurno ×elite obrisati partnera <strong>@Model.Naziv</strong>?</p>
    <p class="text-muted">Tip: @Model.Tip.ToString() | Kontakt: @Model.Kontakt</p>
</div>

<form asp-action="Obrisi">
    <input asp-for="Id" type="hidden" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">Da, obriÜi</button>
        <a asp-action="Index" class="btn btn-secondary">Odustani</a>
    </div>
</form>