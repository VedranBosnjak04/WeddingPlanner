@model WeddingPlanner.Core.Models.Bend
@using WeddingPlanner.Core.Models
@{
    ViewData["Title"] = Model.Partner.Naziv;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Partner.Naziv @(Model.JeDJ ? "(DJ)" : "(Bend)")</h2>
    <div>
        <a asp-action="Uredi" asp-route-id="@Model.Id" class="btn btn-warning">Uredi</a>
        <a asp-action="Index" class="btn btn-secondary">Nazad</a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <p>Kontakt: @Model.Partner.Kontakt</p>
        <p>
            Status:
            <span class="badge @(Model.Status == StatusBenda.Slobodan ? "bg-success" : "bg-danger")">
                @Model.Status.ToString()
            </span>
        </p>

        <form asp-action="PromijeniStatus" method="post" class="d-flex gap-2 align-items-end mb-3">
            <input type="hidden" name="id" value="@Model.Id" />
            <div>
                <label class="form-label">Brza promjena statusa:</label>
                <select name="status" class="form-select">
                    <option value="0">Slobodan</option>
                    <option value="1">Zauzet</option>
                </select>
            </div>
            <button type="submit" class="btn btn-outline-primary">Promijeni</button>
        </form>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <h5>Playliste</h5>
        <ul class="list-group mb-3">
            @foreach (var p in Model.Playliste)
            {
                <li class="list-group-item">@p.Naziv — <em>@p.Zanr</em></li>
            }
        </ul>
    </div>
    <div class="col-md-6">
        <h5>Cijene</h5>
        <table class="table table-sm">
            <thead><tr><th>Kategorija</th><th>Trajanje</th><th>Cijena</th></tr></thead>
            <tbody>
                @foreach (var c in Model.Cijene.OrderBy(c => c.Kategorija))
                {
                    <tr>
                        <td>@c.Kategorija.ToString()</td>
                        <td>@c.TrajanjeH h</td>
                        <td>@c.Iznos.ToString("F2") KM</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>