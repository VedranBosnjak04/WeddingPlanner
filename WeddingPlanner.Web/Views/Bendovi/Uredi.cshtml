@model WeddingPlanner.Core.Models.Bend
@{
    ViewData["Title"] = "Uredi bend";
}

<h2>Uredi: @Model.Partner.Naziv</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Uredi">
            <input asp-for="Id" type="hidden" />
            <input asp-for="PartnerId" type="hidden" />

            <p><strong>Partner:</strong> @Model.Partner.Naziv (ne mijenja se ovdje)</p>

            <div class="mb-3 form-check">
                <input asp-for="JeDJ" class="form-check-input" type="checkbox" />
                <label asp-for="JeDJ" class="form-check-label">Ovo je DJ</label>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label">Status</label>
                <select asp-for="Status" class="form-select"
                        asp-items="Html.GetEnumSelectList<WeddingPlanner.Core.Models.StatusBenda>()"></select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">Ažuriraj</button>
                <a asp-action="Index" class="btn btn-secondary">Odustani</a>
            </div>
        </form>
    </div>
</div>