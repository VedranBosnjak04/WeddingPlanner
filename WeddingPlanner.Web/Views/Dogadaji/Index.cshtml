@model IEnumerable<WeddingPlanner.Core.Models.Dogadaj>
@{
    ViewData["Title"] = "Vjenčanja / Događaji";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Vjenčanja i događaji</h2>
    <a asp-action="Dodaj" class="btn btn-success">Dodaj događaj</a>
</div>

@if (TempData["Uspjeh"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Uspjeh"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>
                    <a asp-action="Index" asp-route-sort="@(ViewBag.CurrentSort == "par" ? "par_desc" : "par")"
                       class="text-white text-decoration-none">Par</a>
                </th>
                <th>
                    <a asp-action="Index" asp-route-sort="@(ViewBag.CurrentSort == "datum" ? "datum_desc" : "datum")"
                       class="text-white text-decoration-none">Datum</a>
                </th>
                <th>Tip vjenčanja</th>
                <th>Status</th>
                <th>Akcije</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model)
            {
                <tr>
                    <td><strong>@d.NazivPara</strong></td>
                    <td>@d.DatumDogadaja.ToString("dd.MM.yyyy")</td>
                    <td><span class="badge bg-info text-dark">@d.TipVjencanja.Naziv</span></td>
                    <td>@d.Status.ToString()</td>
                    <td>
                        <a asp-action="Detalji" asp-route-id="@d.Id" class="btn btn-sm btn-outline-info">Detalji</a>
                        <a asp-action="Uredi" asp-route-id="@d.Id" class="btn btn-sm btn-outline-warning">Uredi</a>
                        <a asp-action="Obrisi" asp-route-id="@d.Id" class="btn btn-sm btn-outline-danger">Obriši</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav>
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-sort="@ViewBag.CurrentSort">@i</a>
                </li>
            }
        </ul>
    </nav>
}